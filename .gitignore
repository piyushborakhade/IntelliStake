# ──────────────────────────────────────────────────────────────
# IntelliStake .gitignore
# ──────────────────────────────────────────────────────────────

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Pytest
.pytest_cache/

# Node / React
node_modules/
dist/
.cache/
npm-debug.log*

# macOS
.DS_Store
._*

# IDE
.vscode/
.idea/
*.swp
*.swo

# Secrets & environment
.env
.env.local
secrets.json
*.pem
*.key

# Jupyter
.ipynb_checkpoints/
*.ipynb

# ── Large ML model binaries ────────────────────────────────────
models/autogluon/
*.pkl
*.cbm
*.ubj

# ── Blockchain build artifacts (regenerated by hardhat compile) ─
blockchain/artifacts/
blockchain/cache/
blockchain/oracle_tx_log.json
blockchain/demo_record.json

# ── Dashboard build output (regenerated by npm run build) ──────
dashboard/dist/

# ── Engine training artifacts ──────────────────────────────────
engine/catboost_info/
engine/archived_scripts/

# ── Parquet files (binary) ─────────────────────────────────────
*.parquet

# ── Large raw/cleaned data files (>50 MB) ──────────────────────
unified_data/raw/intellistake_risk_signals.json
unified_data/raw/intellistake_startups.json
unified_data/raw/github_repositories.json
unified_data/raw/startup_valuation_high_growth.json
unified_data/raw/startup_valuation_high_growth.csv
unified_data/cleaned/intellistake_startups_clean.json
unified_data/external_data/startups_enriched_high_impact.json
unified_data/4_production/stacked_valuation_summary.json
unified_data/real/intellistake_unified.json

# ── Runtime / pipeline output caches ───────────────────────────
unified_data/4_production/company_cache/
unified_data/outputs/pipeline_risk_audit.csv
unified_data/outputs/pipeline_portfolio_weights.json
unified_data/outputs/pipeline_oracle_tx_log.json

# ── Backup / temp files ────────────────────────────────────────
*.bak
*.bak.json
*.log

# ── Literature PDFs (local only, too large for git) ────────────
docs/Literature/

# ── GitHub Actions (needs 'workflow' PAT scope to push) ────────
.github/

# ── Admin docs ─────────────────────────────────────────────────
docs/Project_Admin/
