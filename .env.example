# IntelliStake — Environment Variables Template
# Copy this file to .env and fill in your values.
# Run: cp .env.example engine/.env  (for backend)
#      cp .env.example dashboard/.env  (for frontend — use VITE_ prefix only)

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_SECRET_KEY=change-me-to-another-random-string
FLASK_ENV=development
FLASK_PORT=5500

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InpzaHdqZm50cXlyZXRiemFueGpiIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM0OTA3MjksImV4cCI6MjA4OTA2NjcyOX0.GWCiI9t0LyrgRznSwq0se_eD8CToYQYCtf_sbHe7y6A   # Server-side only, never expose to frontend

# ── AI / ML ───────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=yneI2ANWp8ANMYWnkeIavILQTxAC4mg4K
OLLAMA_BASE_URL=http://localhost:11434             # Local Ollama fallback

# ── GitHub (for live audit agent) ─────────────────────────────────────────────
GITHUB_TOKEN=ghp_your-github-personal-access-token

# ── Blockchain / Sepolia Testnet ──────────────────────────────────────────────
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your-infura-project-id
# OR: https://eth-sepolia.g.alchemy.com/v2/your-alchemy-key
PRIVATE_KEY=0x_your_wallet_private_key_here       # NEVER commit this to git

# Deployed contract addresses (from blockchain/deployment.json)
IDENTITY_REGISTRY_ADDRESS=0x3427a20B61033e8D5A5bac25aff3EB1C7569689F
ISTK_TOKEN_ADDRESS=0x7F0A6bD2A655C523B42A97B98298e34B8E69e8Bb
INVESTMENT_CONTRACT_ADDRESS=0x1a955Dd02199781DFeBFDfE548786ecdd875f4c7

# ── Redis (optional caching — not yet wired) ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# These go in dashboard/.env (must start with VITE_ to be exposed to browser)
VITE_API_URL=http://localhost:5500
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here         # Safe to expose to browser
VITE_SEPOLIA_CHAIN_ID=11155111
VITE_IDENTITY_REGISTRY=0x3427a20B61033e8D5A5bac25aff3EB1C7569689F
VITE_ISTK_TOKEN=0x7F0A6bD2A655C523B42A97B98298e34B8E69e8Bb
VITE_INVESTMENT_CONTRACT=0x1a955Dd02199781DFeBFDfE548786ecdd875f4c7
